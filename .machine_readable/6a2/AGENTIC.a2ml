#
# AGENTIC.a2ml — AI agent constraints and capabilities for wokelangiser
# Defines what AI agents can and cannot do in this repository.

[metadata]
version = "0.1.0"
last-updated = "2026-03-21"

[agent-permissions]
can-edit-source = true
can-edit-tests = true
can-edit-docs = true
can-edit-config = true
can-create-files = true

[agent-constraints]
# What AI agents must NOT do:
# - Never use banned language patterns (believe_me, unsafeCoerce, etc.)
# - Never commit secrets or credentials
# - Never use banned languages (TypeScript, Python, Go, etc.)
# - Never place state files in repository root (must be in .machine_readable/)
# - Never use AGPL license (use PMPL-1.0-or-later)
# - Never bypass consent state machine (Pending->Granted->Active->Revoked)
# - Never hardcode WCAG contrast thresholds outside Types.idr/main.zig
# - Never remove ARIA label requirements from accessibility checks

[domain-constraints]
# Consent types: OptIn (0), OptOut (1), Withdraw (2), AuditTrail (3)
# WCAG levels: A (0), AA (1), AAA (2)
# Consent states: Pending (0), Granted (1), Active (2), Revoked (3)
# Valid transitions: Pending->Granted, Granted->Active, Active->Revoked, Granted->Revoked
# Contrast thresholds: AA >= 4.5:1 (450), AAA >= 7:1 (700)
# These values MUST match between Idris2 ABI (Types.idr) and Zig FFI (main.zig)

[maintenance-integrity]
fail-closed = true
require-evidence-per-step = true
allow-silent-skip = false
require-rerun-after-fix = true
release-claim-requires-hard-pass = true

[automation-hooks]
# on-enter: Read 0-AI-MANIFEST.a2ml, then STATE.a2ml
# on-exit: Update STATE.a2ml with session outcomes
# on-commit: Run just validate-rsr
